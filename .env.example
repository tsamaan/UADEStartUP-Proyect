COMPOSE_PROJECT_NAME=uade-startup

# Repo paths
BACKEND_PATH=../UADEStartUP-Backend
BACKEND_REPO_URL=https://github.com/tomasbondUade/UADEStartUP-Backend.git
FRONTEND_PATH=../UADEStartUP-Frontend
FRONTEND_REPO_URL=https://github.com/tsamaan/UADEStartUP-Frontend.git

# Backend
BACKEND_PORT=3000
NODE_ENV=development
JWT_SECRET=change-me-in-development
CORS_ORIGINS=http://localhost:3001
JSON_BODY_LIMIT=1mb
TRUST_PROXY=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Frontend
FRONTEND_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000/realtime

# PostgreSQL
POSTGRES_DB=uade_startup
POSTGRES_USER=uade_startup
POSTGRES_PASSWORD=uade_startup
POSTGRES_PORT=5432
DATABASE_URL=postgresql://uade_startup:uade_startup@postgres:5432/uade_startup?schema=public

# MinIO
MINIO_ROOT_USER=uade_startup_minio
MINIO_ROOT_PASSWORD=uade_startup_minio_password
MINIO_BUCKET=uade-startup
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
